# 1. SETUP
import pandas as pd
import numpy as np

# Mocking the evaluation data structure
# In your real code, replace this with your actual experiment results
data = {
    'workflow_type': ['Contract Review', 'Privacy Compliance', 'Regulatory Advisory'] * 5,
    'accuracy_score': [0.88, 0.92, 0.79, 0.85, 0.90, 0.77, 0.89, 0.91, 0.82, 0.86, 0.94, 0.75, 0.87, 0.93, 0.80],
    'latency_sec': [1.2, 1.5, 2.1, 1.1, 1.6, 2.3, 1.3, 1.4, 2.0, 1.2, 1.7, 2.2, 1.1, 1.5, 2.0],
    'hallucination_rate': [0.02, 0.01, 0.05, 0.03, 0.01, 0.06, 0.02, 0.01, 0.04, 0.03, 0.01, 0.07, 0.02, 0.01, 0.05]
}

df = pd.DataFrame(data)

# 2. ANALYSIS
# Calculate mean performance across workflows
summary = df.groupby('workflow_type').mean()
print("Performance Summary by Workflow:")
print(summary)

# 3. VISUALIZATION (Requires matplotlib/seaborn)
import matplotlib.pyplot as plt
import seaborn as sns

plt.figure(figsize=(10, 6))
sns.scatterplot(data=df, x='latency_sec', y='accuracy_score', hue='workflow_type')
plt.title('Accuracy vs. Latency Trade-off in Legal AI Workflows')
plt.show()

# 4. CONCLUSION
# "The data indicates a clear trade-off between architectural complexity (reasoning-heavy tasks) 
# and inference latency. Future iterations should prioritize fine-tuning for specific 
# regulatory domains to mitigate hallucination rates."

